{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "triage-output.json",
  "title": "Triage Output",
  "description": "Schema for the JSON object printed to stdout by scripts/triage.js. Read by the Routine agent (Step 2 of routine-prompt.md) to decide FULL_BRIEFING / QUIET_PERIOD / SILENT_SKIP. Required fields must always be present in a successful run; an `error` field is emitted on failure (in which case other fields may be absent).",
  "type": "object",
  "additionalProperties": true,
  "oneOf": [
    {
      "description": "Error variant — emitted on misconfiguration or unhandled exception. Other fields may be absent.",
      "required": ["error"],
      "properties": {
        "error": { "type": "string" },
        "sendBriefing": { "type": "boolean" }
      }
    },
    {
      "description": "Success variant — full triage output.",
      "required": ["date", "region", "migrationScore", "recommendation", "recommendationReason"],
      "properties": {
        "date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "region": { "type": "string" },
        "birdcastSkipped": { "type": "boolean" },
        "migrationScore": { "type": ["number", "null"], "minimum": 0, "maximum": 10 },
        "recommendation": {
          "type": "string",
          "enum": ["FULL_BRIEFING", "QUIET_PERIOD", "SILENT_SKIP"]
        },
        "recommendationReason": { "type": "string" },
        "lastNight": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "cumulativeBirds": { "type": ["number", "null"] },
                "formattedCount":  { "type": ["string", "null"] },
                "isHigh":          { "type": ["boolean", "null"] },
                "peakDirection":   { "type": ["string", "null"] },
                "peakSpeedMph":    { "type": ["number", "null"] }
              }
            }
          ]
        },
        "notableSpecies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notableCount": { "type": ["integer", "null"], "minimum": 0 },
        "weather": {
          "oneOf": [
            { "type": "null" },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "seasonStatus": { "type": ["string", "null"] },
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 },
        "migration": { "type": ["object", "null"], "additionalProperties": true }
      }
    }
  ]
}
