{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aggregate-output.schema.json",
  "title": "Aggregate Output",
  "description": "Schema for the JSON blob produced by scripts/aggregate.js. Field paths are referenced by routine-prompt.md Step 3. If you rename or restructure fields here, update the prompt documentation AND the schema version comment.",
  "type": "object",
  "required": [
    "date",
    "region",
    "location",
    "migration",
    "weather",
    "birdingWindow",
    "moon",
    "hotspots",
    "notableObservations",
    "listservSightings",
    "hotspotNotes",
    "lifeList",
    "flags",
    "sourceStatus"
  ],
  "additionalProperties": false,
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "ISO date string YYYY-MM-DD for the briefing day"
    },
    "region": {
      "type": "string",
      "description": "eBird region code e.g. US-OH-061"
    },
    "location": {
      "type": "object",
      "required": ["lat", "lng"],
      "additionalProperties": false,
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "migration": {
      "type": "object",
      "required": ["lastNight", "season", "topExpectedSpecies", "narrativeSummary"],
      "additionalProperties": false,
      "properties": {
        "lastNight": {
          "description": "BirdCast last-night migration summary. Null if unavailable.",
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "cumulativeBirds": { "type": ["number", "null"] },
                "formattedCount": { "type": ["string", "null"] },
                "isHigh": { "type": ["boolean", "null"] },
                "peakDirection": { "type": ["string", "null"] },
                "peakSpeedMph": { "type": ["number", "null"] },
                "peakAltitudeFt": { "type": ["number", "null"] }
              }
            }
          ]
        },
        "season": {
          "description": "BirdCast season comparison summary. Null if unavailable. additionalProperties: true because the BirdCast API may surface new sub-fields and we should not break on additions.",
          "oneOf": [
            { "type": "null" },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "topExpectedSpecies": {
          "description": "Top 20 expected species by BirdCast historical frequency. Null if unavailable.",
          "oneOf": [
            { "type": "null" },
            {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "speciesCode", "probability"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string" },
                  "speciesCode": { "type": "string" },
                  "probability": { "type": "number", "minimum": 0, "maximum": 100 }
                }
              }
            }
          ]
        },
        "narrativeSummary": {
          "type": ["string", "null"],
          "description": "Plain-English BirdCast migration summary for the email. Null when BirdCast sources errored (see sourceStatus.birdcastLive / birdcastSeason)."
        }
      }
    },
    "weather": {
      "type": "object",
      "required": ["today", "outlook"],
      "additionalProperties": false,
      "properties": {
        "today": {
          "type": "object",
          "required": ["weatherUnavailable"],
          "additionalProperties": false,
          "properties": {
            "overnight": {
              "description": "NWS overnight weather. Null if unavailable.",
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "windDirection": { "type": ["string", "null"] },
                    "windSpeedMph": { "type": ["number", "null"] },
                    "precipProbability": { "type": ["number", "null"] },
                    "cloudCoverPct": { "type": ["number", "null"] }
                  }
                }
              ]
            },
            "morning": {
              "description": "NWS morning weather. Null if unavailable.",
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "precipProbability": { "type": ["number", "null"] },
                    "tempF": { "type": ["number", "null"] },
                    "cloudCoverPct": { "type": ["number", "null"] }
                  }
                }
              ]
            },
            "migrationInterpretation": { "type": ["string", "null"] },
            "rainImpactNote": { "type": ["string", "null"] },
            "weatherUnavailable": { "type": "boolean" },
            "frontalPassage": { "type": ["boolean", "null"] },
            "falloutPotential": { "type": ["boolean", "null"] },
            "windShiftDetected": { "type": ["boolean", "null"] },
            "clearingDetected": { "type": ["boolean", "null"] },
            "frontalNote": { "type": ["string", "null"] }
          }
        },
        "outlook": {
          "description": "5-day forward outlook. Array of per-day objects. Live runs have richer shape; fixture runs have simpler shape. Both are valid. Items may be null if a day's fetch failed. additionalProperties: true since the per-day shape varies between live and fixture runs.",
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "required": ["date"],
                "additionalProperties": true,
                "properties": {
                  "date": { "type": "string" }
                }
              }
            ]
          }
        }
      }
    },
    "birdingWindow": {
      "type": "object",
      "required": ["civilTwilight", "sunrise"],
      "additionalProperties": false,
      "properties": {
        "civilTwilight": { "type": ["string", "null"] },
        "sunrise": { "type": ["string", "null"] },
        "goldenHourEnd": { "type": ["string", "null"] },
        "solarNoon": { "type": ["string", "null"] },
        "sunset": { "type": ["string", "null"] },
        "activityCutoff": { "type": ["string", "null"] },
        "note": { "type": ["string", "null"] }
      }
    },
    "moon": {
      "type": "object",
      "required": ["phaseName", "illuminationPct", "phase"],
      "additionalProperties": false,
      "properties": {
        "phaseName": { "type": "string" },
        "illuminationPct": { "type": "number", "minimum": 0, "maximum": 100 },
        "phase": { "type": "number", "minimum": 0, "maximum": 1 },
        "migrationNote": { "type": ["string", "null"] }
      }
    },
    "hotspots": {
      "type": "array",
      "description": "Top-5 nearby hotspots ranked by 7-day species count. additionalProperties: true on items because the hotspot record may carry richer eBird fields (lat, lng, recent species lists) added over time.",
      "items": {
        "type": "object",
        "required": ["locId", "name"],
        "additionalProperties": true,
        "properties": {
          "locId": { "type": "string" },
          "name": { "type": "string" },
          "speciesCount7Day": { "type": "number" },
          "speciesCount7d": { "type": "number" },
          "allTimeSpecies": { "type": "number" },
          "county": { "type": ["string", "null"] }
        }
      }
    },
    "notableObservations": {
      "type": "array",
      "description": "Notable eBird observations grouped by species. Each item represents the most recent sighting of a species + its 48h trail.",
      "items": {
        "type": "object",
        "required": [
          "species",
          "speciesCode",
          "location",
          "date",
          "count",
          "isLifer",
          "recentSightings",
          "photo",
          "recording"
        ],
        "additionalProperties": false,
        "properties": {
          "species": { "type": "string" },
          "speciesCode": { "type": ["string", "null"] },
          "location": { "type": ["string", "null"] },
          "date": { "type": ["string", "null"] },
          "count": { "type": ["number", "null"] },
          "locId": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] },
          "isLifer": { "type": "boolean" },
          "recentSightings": {
            "description": "All confirmed sightings of this species within the last 48 hours (up to 5), newest first. Null in fixture data that predates this field.",
            "oneOf": [
              { "type": "null" },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["location", "date"],
                  "additionalProperties": false,
                  "properties": {
                    "location": { "type": ["string", "null"] },
                    "date": { "type": ["string", "null"] },
                    "count": { "type": ["number", "null"] },
                    "locId": { "type": ["string", "null"] }
                  }
                }
              }
            ]
          },
          "photo": {
            "description": "Best photo for this species. Macaulay Library primary, Wikipedia fallback. Null if not found. additionalProperties: true since the media client may surface new fields (license, dimensions) without a schema bump.",
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "url": { "type": ["string", "null"] },
                  "thumbnailUrl": { "type": ["string", "null"] },
                  "photographer": { "type": ["string", "null"] },
                  "attribution": { "type": ["string", "null"] },
                  "source": { "type": ["string", "null"] }
                }
              }
            ]
          },
          "recording": {
            "description": "Best audio recording for this species. Macaulay Library only. Null if not found. additionalProperties: true since the media client may surface new fields without a schema bump.",
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "assetId": { "type": ["string", "number", "null"] },
                  "listenUrl": { "type": ["string", "null"] },
                  "recordist": { "type": ["string", "null"] },
                  "attribution": { "type": ["string", "null"] },
                  "rating": { "type": ["number", "null"] },
                  "source": { "type": ["string", "null"] }
                }
              }
            ]
          }
        }
      }
    },
    "listservSightings": {
      "type": "array",
      "description": "OHIO-BIRDS LISTSERV subject-line sightings. The `body` field is intentionally ABSENT from all items (security: prompt-injection defense — anyone can post to OHIO-BIRDS and the body is unsanitized). additionalProperties: false (with body deliberately not listed as a valid property) means a regression that re-introduces body is rejected by the validator, not just by the runtime strip in aggregate.js.",
      "items": {
        "type": "object",
        "required": ["subject", "url", "source"],
        "additionalProperties": false,
        "properties": {
          "subject": { "type": "string" },
          "species": {
            "type": ["array", "null"],
            "items": { "type": "string" }
          },
          "location": { "type": ["string", "null"] },
          "url": { "type": "string" },
          "source": { "type": "string" }
        }
      }
    },
    "hotspotNotes": {
      "type": "object",
      "description": "Per-hotspot micro-habitat notes keyed by eBird locId. Loaded from data/hotspot-notes.json. May be empty object if file is missing. Per-key sub-object uses additionalProperties: true since hotspot notes are user-curated YAML and the shape evolves.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "lifeList": {
      "description": "Life list summary. Null if data/life-list.json is not loaded.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["totalSpecies", "source"],
          "additionalProperties": true,
          "properties": {
            "totalSpecies": { "type": "number" },
            "source": { "type": "string" }
          }
        }
      ]
    },
    "flags": {
      "type": "object",
      "description": "Derived booleans for fast prompt branching. Each field is TRI-STATE: true = condition present, false = condition absent, null = the source the flag derives from is unavailable (see sourceStatus). The prompt MUST treat null as 'unknown', never as the boolean default.",
      "required": [
        "highMigrationNight",
        "hasNotables",
        "morningRainLikely",
        "favorableOvernightWind",
        "frontalPassage",
        "falloutPotential",
        "liferOpportunities"
      ],
      "additionalProperties": false,
      "properties": {
        "highMigrationNight":     { "type": ["boolean", "null"] },
        "hasNotables":            { "type": ["boolean", "null"] },
        "morningRainLikely":      { "type": ["boolean", "null"] },
        "favorableOvernightWind": { "type": ["boolean", "null"] },
        "frontalPassage":         { "type": ["boolean", "null"] },
        "falloutPotential":       { "type": ["boolean", "null"] },
        "liferOpportunities":     { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "sourceStatus": {
      "type": "object",
      "description": "Per-source health for every external fetch. Values are 'ok', 'ok: <detail>', 'error: <message>', or 'skipped: <reason>' (e.g. ohioBirds for non-OH regions). Fixture runs use a single 'fixture' key with pattern 'ok: <fixtureName>'.",
      "additionalProperties": {
        "type": "string",
        "description": "Source status string. Pattern: 'ok' | 'ok: ...' | 'error: ...' | 'skipped: ...'",
        "pattern": "^(ok|error: |skipped: )"
      }
    },
    "trip": {
      "type": ["object", "null"],
      "description": "Non-null only when the run falls within a trip itinerary leg (travel mode). Tells the prompt to use island-wide / resident-focus framing with BirdCast off. additionalProperties:true — shape is intentionally loose for evolvability.",
      "additionalProperties": true
    },
    "tripGuide": {
      "type": ["object", "null"],
      "description": "Static island birding reference for the active trip leg (sites, endemic targets, seabird/wetland/seasonal/driving notes, cautions), from data/hawaii-hotspot-notes.json. Null on normal home runs. additionalProperties:true — rich nested reference content, intentionally not over-constrained.",
      "additionalProperties": true
    }
  }
}
