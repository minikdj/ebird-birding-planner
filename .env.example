# eBird API key — get at https://ebird.org/api/keygen
EBIRD_API_KEY=

# BirdCast API key — contact https://birdcast.info
BIRDCAST_API_KEY=

# Email sending via Resend — https://resend.com
RESEND_API_KEY=

# Email recipient
BRIEFING_EMAIL_TO=you@example.com

# Sender address — MUST be a verified domain in your Resend account.
# Default @resend.dev only delivers to the Resend account owner's email.
# Verify your own domain at resend.com/domains, then set e.g.:
# BRIEFING_FROM_EMAIL=Birding Briefing <briefing@yourdomain.com>
BRIEFING_FROM_EMAIL=

# Location config (defaults to Cincinnati, OH)
BRIEFING_REGION=US-OH-061
BRIEFING_LAT=39.1
BRIEFING_LNG=-84.5

# Optional: path to your eBird data CSV export for personalized life-list comparisons.
# Download from ebird.org → My eBird → Download My Data → select all and export.
# When set, plan_vacation_birding shows "new to your life list" instead of "rare in Cincinnati".
EBIRD_LIFE_LIST_CSV=

# Triage score thresholds — tune for your region's migration volume.
# Ohio defaults work for mid-continent. Pacific coast users may want lower values.
# Gulf Coast users during spring may want higher FULL_THRESHOLD.
BRIEFING_SCORE_HIGH_BIRDS=500000
BRIEFING_SCORE_MED_BIRDS=100000
BRIEFING_SCORE_LOW_BIRDS=50000
BRIEFING_FULL_THRESHOLD=5
BRIEFING_QUIET_THRESHOLD=2
